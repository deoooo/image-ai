# --- Core Services ---
# Supabase Configuration (for database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Note: Backend uses Service Role Key to bypass RLS for writes
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Storage Services ---
# Cloudflare R2 Configuration (for image storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# --- AI Services ---
# Grsai API Configuration (for image generation)
GRSAI_API_KEY=your_api_key
# GRSAI_API_BASE_URL=https://api.grsai.com (Optional)

# --- Database ---
# Prisma/PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@host:5432/database
# Current Prisma config in prisma.config.ts still reads POSTGRES_URL_NON_POOLING.
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/database

# --- Security ---
# Optional override for the built-in browser session token signing secret.
# SESSION_SECRET=replace_with_a_long_random_secret

# --- Network ---
# Proxy configuration (Optional, for resolving connection issues in some regions)
# HTTPS_PROXY=http://127.0.0.1:7890
